# (cloud-internal). Distinct from API_KODUS_SERVICE_MCP_MANAGER which
# is the address kodus-ai uses to call mcp-manager.
# @optional @type=url
# kodus: audience=cloud
API_MCP_MANAGER_BACKEND_URL=

