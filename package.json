        "dev:yalc:clean": "docker compose -f docker-compose.dev.yml down && docker volume rm kodus-ai_yalc_store || true",
        "yalc:update:flow": "docker compose -f docker-compose.dev.yml exec kodus-api sh -lc \"cd /usr/src/app && yalc update @kodus/flow && pnpm install\"",
        "yalc:update:common": "docker compose -f docker-compose.dev.yml exec kodus-api sh -lc \"cd /usr/src/app && yalc update @kodus/kodus-common && pnpm install\"",
        "yalc:update:all": "docker compose -f docker-compose.dev.yml exec kodus-api sh -lc \"cd /usr/src/app && yalc update @kodus/kodus-common && yalc update @kodus/flow && pnpm install\"",
