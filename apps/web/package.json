{
    "name": "kodus-web",
    "version": "1.0.0",
    "description": "Kodus Web Application - Open Source Development Platform",
    "keywords": [
        "kodus",
        "web",
        "development",
        "platform",
        "kody"
    ],
    "author": "Kodus Tech",
    "packageManager": "pnpm@11.9.0",
    "scripts": {
        "start:dev": "next dev --turbopack --port 3000",
        "dev:first-run": "bash scripts/setup-dev-env.sh",
        "build": "next build",
        "start": "next start",
        "start:qa": "NODE_ENV=production next start",
        "lint": "eslint . --config eslint.config.js",
        "check-types": "npx tsc --noEmit",
        "build-analyze": "cross-env ANALYZE=true next build --webpack",
        "prettier": "prettier --write **/*.{js,jsx,ts,tsx}",
        "format": "prettier --write .",
        "docker:build": "docker compose -f ../../docker-compose.dev.yml build web",
        "docker:start": "docker compose -f ../../docker-compose.dev.yml up web",
        "docker:clean": "docker compose -f ../../docker-compose.dev.yml down",
        "docker:clean-cache": "docker volume rm kodus-ai_web_node_modules_cache kodus-ai_web_next_cache 2>/dev/null || true",
        "docker:reset": "pnpm docker:clean && pnpm docker:start"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.4.0",
        "@microsoft/fetch-event-source": "^2.0.1",
        "@next/third-parties": "16.2.10",
        "@pierre/diffs": "^1.2.12",
        "@radix-ui/themes": "^3.3.0",
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.14.5",
        "@tiptap/core": "^3.27.3",
        "@tiptap/extension-code-block": "^3.27.3",
        "@tiptap/extension-placeholder": "^3.27.3",
        "@tiptap/pm": "^3.27.3",
        "@tiptap/react": "^3.27.3",
        "@tiptap/starter-kit": "^3.27.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@typescript-eslint/parser": "^8.63.0",
        "array-move": "^4.0.0",
        "axios": "^1.18.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "cookies-next": "^6.1.1",
        "date-fns": "^4.4.0",
        "highlight.js": "^11.11.1",
        "jose": "^6.2.3",
        "lucide-react": "^1.23.0",
        "markdown-to-jsx": "^9.8.2",
        "next": "16.2.10",
        "next-auth": "^5.0.0-beta.31",
        "nuqs": "^2.9.0",
        "passport-saml-metadata": "^5.0.0",
        "posthog-node": "^5.40.0",
        "radix-ui": "^1.6.2",
        "react": "19.2.7",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.7",
        "react-easy-sort": "^1.8.0",
        "react-error-boundary": "6.1.2",
        "react-hook-form": "^7.81.0",
        "react-phone-number-input": "^3.4.17",
        "react-select": "^5.10.2",
        "react-syntax-highlighter": "^16.1.1",
        "recharts": "^3.9.2",
        "request-filtering-agent": "^3.2.1",
        "seed-color": "^2.0.1",
        "tailwind-merge": "3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "tiny-invariant": "^1.3.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@next/bundle-analyzer": "16.2.10",
        "@tailwindcss/postcss": "^4.3.2",
        "@tanstack/eslint-plugin-query": "^5.101.2",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "cross-env": "^10.1.0",
        "eslint": "10.6.0",
        "eslint-config-next": "16.2.10",
        "eslint-config-prettier": "^10.1.8",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^18.2.1",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-tailwindcss": "^4.0.6",
        "postcss": "^8.5.16",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.2",
        "typescript": "6.0.3"
    }
}
