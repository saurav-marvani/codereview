{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "monorepo": true,
    "compilerOptions": {
        "builder": "webpack",
        "typeCheck": false,
        "plugins": [
            {
                "name": "@nestjs/swagger/plugin",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true
                }
            }
        ],
        "webpackConfigPath": "webpack.config.js",
        "deleteOutDir": true,
        "webpack": true,
        "watchAssets": true,
        "watchOptions": {
            "poll": false
        }
    },
    "projects": {
        "webhooks": {
            "type": "application",
            "root": "apps/webhooks",
            "entryFile": "main",
            "sourceRoot": "apps/webhooks/src",
            "compilerOptions": {
                "tsConfigPath": "apps/webhooks/tsconfig.json",
                "deleteOutDir": true,
                "assets": [
                    {
                        "include": "libs/common/utils/translations/dictionaries/**",
                        "outDir": "dist/dictionaries"
                    }
                ]
            }
        },
        "api": {
            "type": "application",
            "root": "apps/api",
            "entryFile": "main",
            "sourceRoot": "apps/api/src",
            "compilerOptions": {
                "tsConfigPath": "apps/api/tsconfig.json",
                "deleteOutDir": true,
                "assets": [
                    {
                        "include": "libs/common/utils/translations/dictionaries/**",
                        "outDir": "dist/dictionaries"
                    }
                ]
            }
        },
        "worker": {
            "type": "application",
            "root": "apps/worker",
            "entryFile": "main",
            "sourceRoot": "apps/worker/src",
            "compilerOptions": {
                "tsConfigPath": "apps/worker/tsconfig.json",
                "deleteOutDir": true,
                "assets": [
                    {
                        "include": "libs/common/utils/translations/dictionaries/**",
                        "outDir": "dist/dictionaries"
                    }
                ]
            }
        },
        "analytics-cli": {
            "type": "application",
            "root": "apps/analytics-cli",
            "entryFile": "main",
            "sourceRoot": "apps/analytics-cli/src",
            "compilerOptions": {
                "tsConfigPath": "apps/analytics-cli/tsconfig.json",
                "deleteOutDir": true
            }
        },
        "ast-cli": {
            "type": "application",
            "root": "apps/ast-cli",
            "entryFile": "main",
            "sourceRoot": "apps/ast-cli/src",
            "compilerOptions": {
                "tsConfigPath": "apps/ast-cli/tsconfig.json",
                "deleteOutDir": true
            }
        },
        "mcp-manager": {
            "type": "application",
            "root": "apps/mcp-manager",
            "entryFile": "main",
            "sourceRoot": "apps/mcp-manager/src",
            "compilerOptions": {
                "tsConfigPath": "apps/mcp-manager/tsconfig.json",
                "deleteOutDir": true,
                "assets": [
                    {
                        "include": "apps/mcp-manager/src/config/*.json",
                        "outDir": "dist/apps/mcp-manager/config"
                    }
                ]
            }
        }
    }
}