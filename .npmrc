# Google Artifact Registry Configuration
@kodus:registry=https://us-central1-npm.pkg.dev/kodus-infra-prod/kodus-pkg/

# Fallback para npm público (para outras dependências)
registry=https://registry.npmjs.org/

# Configurações de segurança
audit-level=moderate
fund=false

# pnpm: layout de node_modules igual ao do yarn (hoisted) para não quebrar
# imports de dependências não declaradas (phantom deps) herdados da era yarn1.
node-linker=hoisted
