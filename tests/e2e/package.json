{
    "name": "kodus-e2e",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "End-to-end quality gates for Kodus releases",
    "scripts": {
        "scenario": "tsx cli/run-scenario.ts",
        "matrix": "tsx cli/run-matrix.ts",
        "dry-run": "tsx cli/run-matrix.ts matrix/fast.yml --dry-run",
        "benchmark:models": "tsx benchmark/run.ts",
        "benchmark:scorecard": "tsx benchmark/scorecard.ts",
        "benchmark:recollect": "tsx benchmark/recollect.ts",
        "benchmark:provision": "tsx benchmark/provision-repos.ts",
        "test": "node --import tsx --test lib/__tests__/*.test.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "playwright": "^1.48.0",
        "undici": "^8.3.0",
        "yaml": "^2.6.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0"
    }
}
