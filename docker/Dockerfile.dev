# syntax=docker/dockerfile:1.7
# Enables --mount=type=cache. Requires BuildKit (default in Docker 23+).

ARG API_CLOUD_MODE=false
ARG RELEASE_VERSION=local
ARG BUN_VERSION=1.2.12

# Dedicated stage for the bun binary — Docker Hub is more reliable than
# GitHub releases for build-time downloads (prevents flaky 504s during CI).
FROM docker.io/oven/bun:${BUN_VERSION}-debian AS bun-source

FROM docker.io/library/node:22.22.2-slim

ARG API_CLOUD_MODE
ARG RELEASE_VERSION
ENV API_CLOUD_MODE=${API_CLOUD_MODE}
ENV RELEASE_VERSION=${RELEASE_VERSION}
ENV SENTRY_RELEASE=${RELEASE_VERSION}

WORKDIR /usr/src/app
ENV NODE_ENV=development
ENV NODE_OPTIONS="--max-old-space-size=4096"

RUN corepack disable \
 && npm i -g pnpm@11.7.0

# sharing=private (not locked): the dev images build sequentially, so there is
# never legitimate concurrent apt access. With sharing=locked, a build killed
# mid-apt (Ctrl-C/OOM) leaves the cache lock held in buildkitd, and the next
# build blocks forever waiting for it. private gives each build its own cache
# instance and sidesteps that deadlock entirely.
RUN --mount=type=cache,target=/var/cache/apt,sharing=private \
    --mount=type=cache,target=/var/lib/apt,sharing=private \
    rm -f /etc/apt/apt.conf.d/docker-clean \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
      ca-certificates python3 make g++ procps git ripgrep

# Copy the bun binary from the official image and install kodus-graph globally.
COPY --from=bun-source /usr/local/bin/bun /usr/local/bin/bun
RUN bun install -g @kodus/kodus-graph

RUN npm i -g yalc nodemon @ast-grep/cli

COPY package.json pnpm-lock.yaml .npmrc ./
COPY nest-cli.json tsconfig*.json ./

COPY packages/kodus-common ./packages/kodus-common
COPY packages/kodus-flow ./packages/kodus-flow

# Build local packages first. Shared pnpm store mount survives across
# rebuilds so dependency changes don't trigger a full re-download.
#
# `sharing=shared` lets the parallel service builds
# (api/worker/webhooks/worker-analytics/mcp-manager) all use the store
# concurrently — pnpm's content-addressable store is designed for
# concurrent access (atomic writes), unlike yarn1's cache which needed
# careful lock handling here historically.
RUN --mount=type=cache,target=/pnpm-store,sharing=shared \
    cd packages/kodus-common \
  && pnpm install --store-dir /pnpm-store \
  && pnpm run prepack
RUN --mount=type=cache,target=/pnpm-store,sharing=shared \
    cd packages/kodus-flow \
  && pnpm install --store-dir /pnpm-store \
  && pnpm run build

# Install dependencies and link local packages.
# pnpm-workspace.yaml is copied HERE (not with the manifests above) so the
# kodus-common / kodus-flow sub-builds don't see /usr/src/app as a workspace
# root and install into it (`../..`). Only the root install below needs it —
# it carries the `overrides` that must match the lockfile under --frozen-lockfile.
COPY pnpm-workspace.yaml ./
RUN --mount=type=cache,target=/pnpm-store,sharing=shared \
    pnpm install --frozen-lockfile --store-dir /pnpm-store
RUN rm -rf node_modules/@kodus/kodus-common && cp -r packages/kodus-common node_modules/@kodus/kodus-common

COPY --chmod=0755 docker/dev-entrypoint.sh /usr/local/bin/dev-entrypoint

ENTRYPOINT ["/usr/local/bin/dev-entrypoint"]
# Fallback only — each service in docker-compose.dev.yml overrides this with
# its own `command:` (start:dev:api / :worker / :webhooks). There is no root
# `start:dev` script; `start:dev:all` runs the three apps via concurrently.
CMD ["pnpm", "run", "start:dev:all"]
